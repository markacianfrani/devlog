{
  "name": "devlog",
  "version": "1.1.0",
  "description": "Archive AI assistant conversations (Claude Code, opencode, pi)",
  "bin": {
    "devlog": "./src/archive.ts"
  },
  "type": "module",
  "scripts": {
    "start": "bun src/archive.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "check": "bun run lint && bun test && bun run typecheck",
    "lint": "oxlint --tsconfig tsconfig.json .",
    "lint:fix": "oxlint --tsconfig tsconfig.json --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "prek install"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@j178/prek": "0.3.3",
    "@types/bun": "1.3.6",
    "@types/node": "^20.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.31.0",
    "oxlint-tsgolint": "latest",
    "typescript": "^5.0.0"
  }
}
